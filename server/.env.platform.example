# Шаблон env-переменных для Platform API
# Скопировать в .env (не коммитить!) и заполнить реальными значениями.

# ── Webkassa (ОФД для фискализации) ─────────────────────────────────────────
# Тестовая среда: https://devkkm.webkassa.kz/
# Продакшн:      https://api.webkassa.kz/  (после перевода в прод)
WEBKASSA_BASE_URL=https://devkkm.webkassa.kz
WEBKASSA_API_KEY=WKD-XXXX-XXXX-XXXX-XXXX

# Учётка интегратора (email/пароль из регистрации)
WEBKASSA_LOGIN=
WEBKASSA_PASSWORD=

# Заводской номер кассы — получишь после создания тестовой кассы в ЛК.
# Формат типа SWK00000123 или подобный.
WEBKASSA_KASSA_NUMBER=

# Сколько минут кэшировать JWT-токен авторизации (обычно Webkassa выдаёт на час)
WEBKASSA_TOKEN_TTL_MIN=55

# ── Platform API в целом ────────────────────────────────────────────────────
# Включить ли реальную фискализацию (false = мок, true = реальные запросы в Webkassa).
# По умолчанию false — пока тестируем без отправки.
PLATFORM_FISCALIZATION_ENABLED=false

# Email для алертов на провалы фискализации
PLATFORM_ALERT_EMAIL=
